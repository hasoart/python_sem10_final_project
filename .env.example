APP_NAME="Object Detection Service"
DEBUG=false
CORS_ALLOW_ORIGINS='["*"]'

# Local run values. Docker Compose overrides service URLs inside containers.
DATABASE_URL="postgresql+psycopg://app:app@localhost:5433/object_detection"
DATABASE_ECHO=false

REDIS_URL="redis://localhost:6379/0"
CELERY_APP_NAME="object_detection_service"
CELERY_TIMEZONE="UTC"
CELERY_LOG_LEVEL="info"

S3_ENDPOINT_URL="http://localhost:9000"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"
S3_BUCKET_NAME="object-detection"

YOLO_MODEL_PATH="yolo11n.pt"
YOLO_CONFIDENCE=0.25

POSTGRES_DB="object_detection"
POSTGRES_USER="app"
POSTGRES_PASSWORD="app"
MINIO_ROOT_USER="minioadmin"
MINIO_ROOT_PASSWORD="minioadmin"

API_PORT=8000
POSTGRES_PORT=5433
REDIS_PORT=6379
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
